{

   "layer": "top",
   "position": "top",
   "modules-left": ["custom/power_button", "clock"],
   "modules-center": ["hyprland/workspaces"],
   "modules-right": ["tray", "pulseaudio", "battery"],

   "tray": {
    "icon-size": 21,
    "spacing": 10,
    "reverse-direction": true
   },

   "clock": {
      "format": "{:%a %d %b %H:%M}",
      "on-click": "korganizer"
   },

   "custom/power_button": {
      "format": " ⏻ ",
      "tooltip": false,
      "on-click": "$HOME/.config/waybar/scripts/power_menu.sh %x %y"
   },

   "battery": {
      "format": "{capacity}% {icon}",
      "format-full": "{capacity}% ",
      "format-icons": ["", "", "", "", ""],
      "on-click": "notify-send 'Battery Info' \"$(upower -i /org/freedesktop/UPower/devices/battery_BAT0 | grep -E 'state|to full|to empty|percentage')\"",
      "interval": 15
   },

   "pulseaudio": {
      "format": "{volume}% {icon}",
      "format-muted": "{volume}% \uf6a9",
      "format-icons": ["", ""],  // Font Awesome mute and high volume icons
      "on-click": "pavucontrol"
   }
}
